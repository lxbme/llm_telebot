# ── OpenAI / Compatible API ───────────────────────────────────────────────────
# Base URL of the OpenAI-compatible endpoint. Must end with /v1
OPENAI_API_BASE=https://api.openai.com/v1

# Your API key / token
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model name to use for completions
OPENAI_MODEL=gpt-4o

# ── Telegram ──────────────────────────────────────────────────────────────────
# Token obtained from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Bot username *with* the @ prefix – used to detect mentions in groups
BOT_USERNAME=@mybot

# ── Behaviour ─────────────────────────────────────────────────────────────────
# System prompt injected as the first message in every API call
SYSTEM_PROMPT=You are a helpful, concise, and friendly AI assistant.

# Maximum number of user+assistant messages to keep per chat (sliding window)
CONTEXT_MAX_MESSAGES=20

# Maximum number of tokens the model may generate per reply (0 = no limit)
MAX_TOKENS=0

CONTEXT_MODE=at

AUTO_DETECT=false

# ── Auto-Detect Model (optional) ──────────────────────────────────────────────
# Separate, lighter model used only for the AUTO_DETECT relevance classifier.
# If not set, the main OPENAI_* settings above are used.

# API base URL for the detector model (falls back to OPENAI_API_BASE)
# AUTO_DETECT_API_BASE=https://api.openai.com/v1

# API key for the detector model (falls back to OPENAI_API_KEY)
# AUTO_DETECT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model name for the detector (falls back to OPENAI_MODEL)
# AUTO_DETECT_MODEL=gpt-4o-mini

# ── User Profile Extraction ──────────────────────────────────────────────────
# Enable automatic user-profile extraction from conversations (NoSQL / bbolt).
# Only users with a TG username are profiled. Profiles are injected into the
# system prompt so the LLM knows who it's talking to.
# NOTE: Extraction is purely passive — it only runs after a bot reply.
# No API calls are made when there is no user activity.
PROFILE_ENABLED=true

# Path to the bbolt database file for storing user profiles.
PROFILE_DB_PATH=./data/profiles.db

# Trigger a background profile-extraction LLM call every N bot-replies per user.
# Also subject to a 2-minute minimum cooldown between extractions.
PROFILE_EXTRACT_EVERY=3

# Separate, lighter model used only for profile extraction.
# If not set, the main OPENAI_* settings above are used.

# API base URL for profile extraction (falls back to OPENAI_API_BASE)
# PROFILE_API_BASE=https://api.openai.com/v1

# API key for profile extraction (falls back to OPENAI_API_KEY)
# PROFILE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model name for profile extraction (falls back to OPENAI_MODEL)
# PROFILE_MODEL=gpt-4o-mini