# 优先将业务配置写入 `config.yaml`。
# 本文件建议仅保存密钥、容器路径覆盖或临时环境变量 override。

# 可选：指定配置文件路径；默认是 ./data/config.yaml
# CONFIG_FILE=./data/config.yaml

# 必填：OpenAI 兼容 API 密钥
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 必填：Telegram Bot Token
TELEGRAM_BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# 可选：如果需要覆盖 config.yaml 中的值，再取消对应注释。
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
# BOT_USERNAME=@mybot
# MCP_CONFIG_PATH=./mcp_config.json
# CHAT_DB_PATH=./data/chat.db
# PROFILE_DB_PATH=./data/profiles.db
# USER_MCP_DB_PATH=./data/user_mcp.db

# 可选：独立模型密钥覆盖
# AUTO_DETECT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PROFILE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SUMMARY_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选：火山 TTS 密钥
# VOLCENGINE_TTS_APP_ID=
# VOLCENGINE_TTS_ACCESS_KEY=