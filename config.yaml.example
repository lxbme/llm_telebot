# 主配置文件示例。
# 推荐将大部分可热修改配置放在这里，通过 /admin 修改时也会写回本文件。
# 启动时环境变量会覆盖同名配置，因此 .env 更适合只放密钥或临时 override。

# ── OpenAI / Compatible API ───────────────────────────────────────────────────
OPENAI_API_BASE: https://api.openai.com/v1
OPENAI_API_KEY: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL: gpt-4o

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN: 1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
BOT_USERNAME: "@mybot"

# ── Behaviour ─────────────────────────────────────────────────────────────────
SYSTEM_PROMPT: |
  You are a helpful, concise, and friendly AI assistant.
CONTEXT_MAX_MESSAGES: 20
MAX_TOKENS: 0
CONTEXT_MODE: at
AUTO_DETECT: false

# ── Auto-Detect Model (optional) ──────────────────────────────────────────────
AUTO_DETECT_API_BASE: ""
AUTO_DETECT_API_KEY: ""
AUTO_DETECT_MODEL: ""

# ── Access Control ────────────────────────────────────────────────────────────
# 逗号分隔的 Telegram ID；留空表示不限制。
ALLOWED_USERS: ""
ALLOWED_GROUPS: ""
ADMIN_ID: ""

# ── User Profile Extraction ───────────────────────────────────────────────────
PROFILE_ENABLED: true
PROFILE_DB_PATH: ./data/profiles.db
PROFILE_EXTRACT_EVERY: 3
PROFILE_API_BASE: ""
PROFILE_API_KEY: ""
PROFILE_MODEL: ""

# ── Conversation Summary ──────────────────────────────────────────────────────
SUMMARY_ENABLED: true
SUMMARY_MIN_OVERFLOW: 6
SUMMARY_API_BASE: ""
SUMMARY_API_KEY: ""
SUMMARY_MODEL: ""

# ── Tool Calling (MCP) ────────────────────────────────────────────────────────
TOOLS_ENABLED: false
TOOLS_MAX_ITERATIONS: 5
MCP_CONFIG_PATH: ./mcp_config.json
USER_MCP_DB_PATH: ./data/user_mcp.db

# ── Persistent Chat Storage ───────────────────────────────────────────────────
CHAT_DB_PATH: ./data/chat.db

# ── SSH TUI Dashboard ─────────────────────────────────────────────────────────
# 通过 SSH 登录只读 TUI 看板。启用前请先准备 host key 和 authorized_keys。
DASHBOARD_SSH_ENABLED: false
DASHBOARD_SSH_LISTEN: :23234
DASHBOARD_SSH_HOST_KEY_PATH: ./data/dashboard_ssh_ed25519
DASHBOARD_SSH_AUTHORIZED_KEYS_PATH: ./data/dashboard_authorized_keys
DASHBOARD_SSH_IDLE_TIMEOUT: 1h
DASHBOARD_SSH_MAX_SESSIONS: 8

# ── Volcengine TTS ────────────────────────────────────────────────────────────
VOLCENGINE_TTS_APP_ID: ""
VOLCENGINE_TTS_ACCESS_KEY: ""
VOLCENGINE_TTS_RESOURCE_ID: seed-tts-1.0
VOLCENGINE_TTS_SPEAKER: zh_female_shuangkuaisisi_moon_bigtts
VOLCENGINE_TTS_AUDIO_FORMAT: mp3
VOLCENGINE_TTS_SAMPLE_RATE: 24000
VOLCENGINE_TTS_SPEECH_RATE: 0
VOLCENGINE_TTS_SEND_TEXT: true

# ── Telegram Sticker Strategy ──────────────────────────────────────────────────
STICKER_ENABLED: false
STICKER_MODE: append
STICKER_PACK_NAME: ""
STICKER_RULES_PATH: ./data/sticker_rules.json
STICKER_SEND_PROBABILITY: 0.25
STICKER_MAX_PER_REPLY: 1
STICKER_WITH_SPEECH: true
STICKER_ALLOWED_CHATS: ""
STICKER_MODEL_ENABLED: false
STICKER_MODEL_BASE: ""
STICKER_MODEL_KEY: ""
STICKER_MODEL: ""

# ── STT (Speech-to-Text) ──────────────────────────────────────────────────────
# 启用后，机器人可接收 Telegram 语音消息并通过 STT API 转为文字，触发完整对话流程。
# 支持任何兼容 OpenAI /v1/audio/transcriptions 的端点（Whisper、gpt-4o-transcribe 等）。
STT_ENABLED: false
STT_API_BASE: ""
STT_API_KEY: ""
STT_MODEL: whisper-1
STT_DISPLAY: true

# ── MCP Tool Summary (Lazy Loading) ───────────────────────────────────────────
# 启用后，仅将各 MCP server 的摘要注入上下文，LLM 按需调用 get_tool_details 加载完整 schema。
# 可显著减少 token 消耗。推荐配置一个较小/便宜的模型来生成摘要。
# 摘要持久化到 user_mcp.db，工具列表变化时自动失效并重新生成。
TOOLS_SUMMARY_ENABLED: false
TOOLS_SUMMARY_API_BASE: ""
TOOLS_SUMMARY_API_KEY: ""
TOOLS_SUMMARY_MODEL: ""
